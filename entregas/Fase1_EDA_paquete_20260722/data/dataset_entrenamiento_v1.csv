# Validar si una declaración de objetivo cumple con las restricciones mínimas de

SMART

import re

def validar_integridad_smart(objetivo_json):

# Verificación de cuantificación (M) y acotamiento temporal (T) en la

sintaxis

contiene_metrica = bool(re.search(r'\d+%', objetivo_json[""declaracion""]))
contiene_tiempo = bool(re.search(r'Q[1-4]\s\d{4}|[A-Za-z]+\s\d{4}',

objetivo_json[""declaracion""]))

if contiene_metrica and contiene_tiempo:

objetivo_json[""estado""] = ""SMART Validado""

else:

objetivo_json[""estado""] = ""Invalido: Falta metrica cuantitativa (%) o

indicador de tiempo""

return objetivo_json

# Objetivos del caso metodológico de referencia
obj_valido = {""id"": ""OBJ_01"", ""declaracion"": ""Reducir costos logisticos un 15%

para el Q2 2026 mediante optimizacion de ruteo""}

obj_invalido = {""id"": ""OBJ_02"", ""declaracion"": ""Mejorar las ventas de la empresa

""}

print(validar_integridad_smart(obj_valido))
print(validar_integridad_smart(obj_invalido))

